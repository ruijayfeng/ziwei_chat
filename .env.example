DATABASE_URL="postgres://ziwei:ziwei@localhost:5432/ziwei_chat"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Configure a Vercel AI SDK provider before enabling live model calls.
AI_PROVIDER="deterministic-local"
AI_MODEL=""
OPENAI_API_KEY=""

# Basic API abuse protection for /api/chat.
CHAT_RATE_LIMIT_MAX="30"
CHAT_RATE_LIMIT_WINDOW_MS="60000"

# Optional enhanced retrieval. Local Markdown/keyword search must work without this.
EMBEDDING_PROVIDER_API_KEY=""
EMBEDDING_MODEL=""

# Optional Vercel/Neon production settings.
VERCEL_PROJECT_PRODUCTION_URL=""
NEON_DATABASE_URL=""
