DATABASE_URL="postgres://ziwei:ziwei@localhost:5432/ziwei_chat"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Basic API abuse protection for /api/chat.
CHAT_RATE_LIMIT_MAX="30"
CHAT_RATE_LIMIT_WINDOW_MS="60000"

# Model calls are configured in the browser model settings panel for beta.
# API keys entered there are stored in browser localStorage, not in this file.

# Optional enhanced retrieval. Local Markdown/keyword search works without this.
# Used by `npm run build:knowledge-embeddings` for offline index creation.
EMBEDDING_BASE_URL="https://api.openai.com/v1"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"

# Optional Vercel/Neon production settings.
VERCEL_PROJECT_PRODUCTION_URL=""
NEON_DATABASE_URL=""
